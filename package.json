{
  "name": "ims",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean:build": "turbo clean:build --concurrency=20",
    "clean:packages": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && rm -f pnpm-lock.yaml",
    "clean:all": "pnpm run clean:build && pnpm run clean:packages",
    "dev": "TURBO_UI=0  turbo dev --concurrency=20",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "turbo": "^2.8.1",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  }
}
