model Item {
  id                    String                  @id() @default(uuid())
  name                  String                  @db.VarChar(255)
  description           String?
  purchasePrice Decimal @db.Decimal(10, 2)
  salesPrice    Decimal @db.Decimal(10, 2)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  unit                  String
  baseUnit              Unit                    @relation(fields: [baseUnitId], references: [id], onDelete: Cascade)
  baseUnitId            String
  sku                   String?

  barcode               String?
  returnable            Boolean
  PackedWeight          Float?
  PackedHeight          Float?
  PackedWidth           Float?
  PackedDepth           Float?
  Refrigerated          Boolean                 @default(false)
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt()

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("items")
}

/// Represents a classification of units based on their physical dimension
/// (e.g., WEIGHT, LENGTH, VOLUME).
///
/// Design:
/// - Supports both global categories (organizationId = null)
///   and organization-specific custom categories.
/// - Used to enforce valid unit conversions (same category only).
///
/// Examples:
/// - Global: WEIGHT, LENGTH
/// - Custom (per org): PACKAGING, FABRIC_DENSITY
model UnitCategory {
  id   String @id @default(uuid())
  name String

  // optional organization scope
  organizationId String? 
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  units Unit[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, organizationId])
}
model Unit {
  id     String @id @default(uuid())
  name   String // "Kilogram"
  symbol String // "kg"


  category   UnitCategory @relation(fields: [categoryId], references: [id])
  categoryId String

  // Organization scoping
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  items Item[]

  // Relations (same-category conversions only)
  baseConversions   UnitConversion[] @relation("BaseUnit")
  targetConversions UnitConversion[] @relation("TargetUnit")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@unique([organizationId, symbol])

  @@index([categoryId]) // 🔥 important for filtering
  @@map("units")
}

model UnitConversion {
  id String @id @default(uuid())

  baseUnit   Unit   @relation("BaseUnit", fields: [baseUnitId], references: [id], onDelete: Cascade)
  baseUnitId String

  targetUnit   Unit   @relation("TargetUnit", fields: [targetUnitId], references: [id], onDelete: Cascade)
  targetUnitId String

  item   Organization? @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId String?

  factor Decimal? @db.Decimal(10, 5) // Conversion factor from base unit to target unit
  // Example:
  // 1 kg = 1000 g → factor = 1000
  // 1 box = 12 pieces → factor = 12

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([baseUnitId, targetUnitId])
  @@map("item_unit_conversions")
}

model ItemUnitPrice {
  id String @id @default(uuid())
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId String
  purchasePrice Decimal @db.Decimal(10, 2)
  salesPrice    Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, unitId])
  @@map("item_unit_prices")
}