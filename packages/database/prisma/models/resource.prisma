
enum ResourceName {
  user
  role
  item
  unit
  unitCollection
  invoice
  customer
  supplier
  purchaseOrder
  salesOrder
  warehouse
  organization
  organizationUser
  report
}

model Resource {
  id          String       @id @default(uuid())
  name        ResourceName @unique
  description String?
  permissions Permission[]
  sidebarOption SidebarOption?

}
